# population tab
@pop_category_width = 1177
# sidebar
@sidebar_width = 450
@sidebar_list_height = 830
# districts
@district_rows = 10 # used in height calculation for districts_grid_box


### Used By BPVR 

@ROW_FACTOR = 1 # Change this to switch between 1 row and 2 row planet view

# move the planet resources box to the side window
@resource_offset_x = 315
@resource_offset_y = -190

# Move down the build queue to leave space for resources, also shrink the inner space accordingly
@build_queue_offset_y = 185

# Widen the districts window, also shrink the sencodary districts space
@main_district_size_dx = 310
@main_district_size_dy = 70

# The inner scroll area size of main district, should contains all zones and rows
# Currently must larger than 20 rows, each row 52 height + some margin)
@main_district_scroll_x = 1200

# Primary zone size change
@primary_zone_size_x = 320 # 50(slot width) * 6 + 2(gutter width) * 5 + 5(margin) * 2
@primary_zone_size_y = 1048 # 50(slot height) * 10 + 2(gutter height) * 9 + 5(margin) * 2
@primary_zone_slot_h = 6 # number of slots in primary zone row

# Sencondary zone size and location change
@secondary_zone_x = 420 # 320 + 80 (icon size) + 20 (margin)
@secondary_zone_size_x = 450 # @primary_zone_size_x + 130 (label)
@secondary_zone_slot_h = 6

# Sencondary district size change
@secondary_district_size_y = 185 #Single: 185 Double: 260

@secondary_district_slot_h = 3 # number of slots in secondary district row
@secondary_district_slot_v = 2 # number of slots in secondary district column
@district_card_title_x = 8
@district_card_title_y = 0
@district_card_triggered_name_y = 15
@district_card_build_button_x = -102

### END Used By BPVR

