@general_scale = 0.85

@orbital_station = 17
@research_station = 13
@mining_station = 13
@terraforming_station = 13

entity = {
 	name = "starfleet_nx_research_station_entity"
 	pdxmesh = "starfleet_nx_science_station_mesh"
 	locator = { name = "part1" 			position = { 0 	0 	0 } }
 	default_state = "idle"
 	state = { name = "idle" 
 		start_event = { trigger_once = yes sound = { soundeffect = "amb_research_station_signals" } }		
 	}
 	scale = @general_scale
 	game_data = { size = @research_station }
}
entity = {
 	name = "starfleet_nx_research_station_section_entity"
