@frame_scale = 0.48 #0.4375 #0.35
@frame_size = 11.0 # 16.0


##################         	 SCX_CARRIER           ########################

# FRAME
entity = {
	name = "biomass_01_SCX_Carrier_entity"
	pdxmesh = "molluscoid_01_SCX_dreadnought_frame_mesh"

	#locator = { name = "part1"	position = { 0 0 -13.2 } rotation = { 0 0 0 } }
	#locator = { name = "part2"	position = { 0 0 -6.0 } rotation = { 0 0 0 } }
	#locator = { name = "part3"	position = { 0 0 6.0 } rotation = { 0 0 0 } }
	#locator = { name = "part4"	position = { 0 0 10.9 } rotation = { 0 0 0 } }
	
	default_state = "idle"
	state = { name = "idle"	state_time = 5
		start_event = { trigger_once = yes sound = { soundeffect = "swarm_small_warship_idle" } }
	}
	state = { name = "moving"	state_time = 5
		event = { trigger_once = yes sound = { soundeffect = "swarm_generic_idle" } }
	}
	state = { name = "death" state_time = 8
		event = { time = 0.0 node = "explosion_locator1" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.0 node = "explosion_locator2" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.0 node = "explosion_locator3" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.0 node = "explosion_locator4" particle = "avian_01_large_ship_explosion_particle" }
		
		event = { time = 0.0 node = "explosion_locator1" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.0 node = "explosion_locator1" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 0.0 node = "explosion_locator2" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.0 node = "explosion_locator2" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 0.5 node = "explosion_locator5" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 0.5 node = "explosion_locator5" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 2.5 node = "explosion_locator6" particle = "avian_small_ship_explosion_particle" }
		event = { time = 2.5 node = "explosion_locator6" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 1.7 node = "explosion_locator7" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 1.7 node = "explosion_locator7" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 0.78 node = "explosion_locator8" particle = "avian_small_ship_explosion_particle" }
		event = { time = 0.78 node = "explosion_locator8" particle = "amoeba_gib_squirt_effect" }
		
		event = { time = 6.5 node = "explosion_locator9" particle = "avian_01_large_ship_explosion_particle" }
		event = { time = 6.5 node = "explosion_locator9" particle = "amoeba_gib_squirt_effect" }

		event = { time = 0.0 particle = "scx_capital_explosion_particle" sound = { soundeffect = ship_destroyed } }
	}
	
	#attach = { part4 = "molluscoid_01_SCX_Carrier_stern_M2_entity" }
	
	scale = @frame_scale
		
	game_data = {
		size = @frame_size
		emissive_recolor_crunch = 10.0
	}
}



