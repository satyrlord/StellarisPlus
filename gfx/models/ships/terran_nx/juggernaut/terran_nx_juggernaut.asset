@general_scale = 1.25
@terran_nx_juggernaut_scale = 18

entity = {
	name = "terran_nx_juggernaut_core_section_entity"
	pdxmesh = "terran_nx_juggernaut_mesh"
	scale = @general_scale
    locator = { name = "part1" position = { 0 0 0 } }
	locator = { name = "root" rotation = { 0 0 0 } }
    
    locator = { name = "xl_gun_01" rotation = { 0 0 0 } }
    locator = { name = "xl_gun_02" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_01" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_02" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_03" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_04" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_05" rotation = { 0 0 0 } }
    locator = { name = "strike_craft_locator_06" rotation = { 0 0 0 } }
    locator = { name = "gun_1" rotation = { 0 0 0 } }
    locator = { name = "gun_2" rotation = { 0 0 0 } }
    locator = { name = "gun_3" rotation = { 0 0 0 } }
    locator = { name = "gun_4" rotation = { 0 0 0 } }
    locator = { name = "gun_5" rotation = { 0 0 0 } }
    
    locator = { name = "sun" position = { 0 0.75 -19.2 } rotation = { 0 0 0 } }
	attach = { "sun" = "small_k_star_class_star_entity" }
}


entity = { # K
	name = "small_k_star_class_star_entity"
	pdxmesh = "star_mesh"
	
	default_state = "idle"
	state = { name = "idle" animation = "idle"
		event = { 
			time = 0.0 
			particle = "k_class_star_particle"  keep_particle = no trigger_once = yes sound = { soundeffect = "amb_star_fusion" } 
        }
		event = { trigger_once = yes sound = { soundeffect = "space_ambient" } }  
		event = { trigger_once = yes sound = { soundeffect = "falling_star" } }
		event = { trigger_once = yes sound = { soundeffect = "space_ambient_layer_02" } }
	}
	scale = 0.3
}

entity = {
	name = "terran_nx_juggernaut_entity"	
	pdxmesh = "molluscoid_01_corvette_frame_mesh"
	default_state = "idle"
	state = { name = "idle"	 animation = "idle" animation_blend_time = 4 }
	state = { name = "moving"	animation = "idle" animation_blend_time = 2 }
	state = { name = "death" animation = "death3" animation_blend_time = 0.0 chance = 1 looping = no 
		event = { time = 4.63 node = "ship_main" particle = "avian_01_large_ship_explosion_particle" }
	}
	scale = 1.0
	game_data = {
		size = @terran_nx_juggernaut_scale
	}
}