entity = {
	name = "chaos_02_juggernaut_core_section_entity"
	pdxmesh = "chaos_02_blackstone_hull_mesh"
	
	default_state = "idle"
	state = { name = "idle"
		event = { trigger_once = yes sound = { soundeffect = juggernaut_humanoid_idle } }
	}
	state = { name = "moving"	
		event = { sound = { soundeffect = juggernaut_humanoid_move } }
	}
	state = { name = "death" looping = no 
	}
	attach = { upper = "chaos_02_juggernaut_parts_entity" }
	attach = { bottom = "chaos_02_juggernaut_parts_entity" }
}

