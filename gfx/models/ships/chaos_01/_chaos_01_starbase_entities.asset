###### Ion Cannon ######

entity = {
	name = "chaos_01_ion_cannon_entity"
	locator = { name = "part1" position = { 0 0 0 } }
}

entity = {
	name = "chaos_01_ion_cannon_section_entity"
	pdxmesh = "chaos_01_ion_cannon_mesh"
	scale = 1.0
	locator = { name = "root" position = { 0 0 0 } }
	
	
	default_state = "idle"
	state = { name = "idle" state_time = 5 
		start_event = { node = "root" particle = "chaos_cannon_core_effect" keep_particle = yes trigger_once = yes }
	}
	attach = { "root" = "chaos_01_ion_cannon_core_entity" }
	attach = { "root" = "chaos_01_ion_cannon_parts_entity" }

}

