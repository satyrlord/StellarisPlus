## ATTENTION - Spy orb destroyed entity has it's own scale ##
@spyorb_scale = 4 
@spyorb_height_pos = 0
@spyorb_side_pos = 0

#####################################################
#####											#####
#####				Biomass						#####
#####											#####
#####################################################
entity = {
	name = "biomass_01_spyorb_part_1_entity"
	pdxmesh = "biomass_01_spyorb_frame_mesh"
	
	default_state = "idle"
	state = { name = "idle"	 animation = "idle" 
		start_event = { trigger_once = yes sound = { soundeffect = "spy_orb_hum_dome" } }
		start_event = { trigger_once = yes sound = { soundeffect = "swarm_big_station_idle" } }
	}
	
	cull_radius = 5000
	
	attach = { "root" = "biomass_01_spyorb_stage1_actual_entity" }
}

