		start_event = { trigger_once = yes sound = { soundeffect = "spy_orb_hum_spire" } }
		start_event = { trigger_once = yes sound = { soundeffect = "swarm_big_station_idle" } }
	}

	game_data = { 
		emissive_recolor_crunch = 10.0
