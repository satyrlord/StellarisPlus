entity = {
	name = "biomass_01_spy_orb_destroyed_entity"
	locator = { name = "base"	position = { 0 0 0 } }	

	default_state = "idle"
	state = { name = "idle" state_time = 10
		start_event = { trigger_once = yes sound = { soundeffect = "spy_orb_destroyed" stop_on_state_change = yes } }
	}
	attach = { "base" = "biomass_01_spyorb_part_3_entity" }
	attach = { "base" = "debris_small_01_entity" }
}

### Actual Models

