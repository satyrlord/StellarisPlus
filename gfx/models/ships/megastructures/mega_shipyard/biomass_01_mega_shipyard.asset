entity = {
	name = "biomass_01_mega_shipyard_01_stage_1_entity"
	
	default_state = "idle"
	state = { name = "idle" state_time = 6.5 }
	state = { name = "death" state_time = 6.6 looping = no 
		event = { time = 6.5 node = "ship_main" particle = "juggernaut_explosion_particle" sound = { soundeffect = ship_destroyed } }
	}
	
	locator = { name = "ship_main" }
	
	attach = { ship_main = "biomass_01_mega_shipyard_01_stage_1_section_entity" }
}

