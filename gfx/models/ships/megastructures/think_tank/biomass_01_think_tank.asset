}


entity = {
	name = "biomass_01_thinktank_part3_entity"
	pdxmesh = "biomass_01_sciencenexus3_mesh"
	
	default_state = "idle"
	state = { name = "idle" state_time = 10
		start_event = { trigger_once = yes sound = { soundeffect = "think_tank_structure_amb_01" stop_on_state_change = yes } }
		start_event = { trigger_once = yes sound = { soundeffect = "think_tank_structure_amb_02" stop_on_state_change = yes } }
		event = { time = 0 node = "center" particle = "think_tank_core_effect" keep_particle = yes trigger_once = yes }
		event = { time = 1.0 node = "static_locator_01" particle = "wraith_tentacle_electricity_yellow_effect" keep_particle = yes trigger_once = no }
		event = { time = 2.0 node = "static_locator_02" particle = "wraith_tentacle_electricity_yellow_effect" keep_particle = yes trigger_once = no }
		event = { time = 3.0 node = "static_locator_03" particle = "wraith_tentacle_electricity_yellow_effect" keep_particle = yes trigger_once = no }
		event = { time = 4.0 node = "static_locator_04" particle = "wraith_tentacle_electricity_yellow_effect" keep_particle = yes trigger_once = no }
		event = { time = 5.0 node = "lower_psi_01" particle = "crystal_ship_center_effect" keep_particle = yes trigger_once = yes sound = { soundeffect = "wraith_spark_01" }}
	}

	cull_radius = 5000
}

