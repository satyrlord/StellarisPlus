entity = {
	name = "biomass_01_thinktank_part1_entity"
	pdxmesh = "biomass_01_sciencenexus1_mesh"
	
	default_state = "idle"
	state = { name = "idle" state_time = 10
		start_event = { trigger_once = yes sound = { soundeffect = "think_tank_core_amb" } }
		event = { time = 0 node = "center" particle = "think_tank_core_effect" keep_particle = yes trigger_once = yes }
	}
}


entity = {
	name = "biomass_01_thinktank_part2_entity"
	pdxmesh = "biomass_01_sciencenexus2_mesh"
	
	default_state = "idle"
	state = { name = "idle" state_time = 10
