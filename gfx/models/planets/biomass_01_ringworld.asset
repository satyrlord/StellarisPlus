@ringworld_segment_size = 50

entity = {
	name = "biomass_01_ringworld_construction_entity"
	cull_radius = 5000.0
	pdxmesh = "biomass_01_ringworld_construct_mesh"
	
	game_data = {
		shader_type = ship
		emissive_recolor_crunch = 10.0
	}
}




entity = {
	name = "biomass_01_ringworld_3x_seams_entity"
	cull_radius = 5000.0
	pdxmesh = "biomass_01_ringworld_construct_mesh"
	
	default_state = "idle"
	state = { name = "idle"
	start_event = { trigger_once = yes sound = { soundeffect = "ringworld_hum_idle_02" stop_on_state_change = yes } }
	}
	
	state = { name = "construction"
	start_event = { trigger_once = yes sound = { soundeffect = "ringworld_construction_ambient" } }
	}
	
	locator = { name = "locator1" 	position = { -225 	0 	-60.289 	} rotation ={ -30 0 0} 	scale = 1}
	locator = { name = "locator2" 	position = {  225 	0 	-60.289		} rotation ={ 30 0 0}	scale = 1}
	
	attach = { locator1 = "biomass_01_ringworld_construction_entity" }
	attach = { locator2 = "biomass_01_ringworld_construction_entity" }
	
	game_data = {
		shader_type = ship
		emissive_recolor_crunch = 10.0
	}
	
	scale = 1
}


entity = {
	name = "biomass_01_ringworld_seam_entity_01_full_entity"
	cull_radius = 10000.0
	
	locator = { name = "ringworld_north" 		position = { 450	0 	0 		} rotation = {	90	0	0	}		}
	locator = { name = "ringworld_south" 		position = { -450	0 	0 		} rotation = {	-90	0	0	}		}
	locator = { name = "ringworld_west" 		position = { 0		0 	450 	} rotation = {	0	0	0	}		}
	locator = { name = "ringworld_east" 		position = { 0		0 	-450 	} rotation = {	180	0	0	}		}	
    
	state = { name = "construction"}
    
	attach = { ringworld_north 		= "biomass_01_ringworld_3x_seams_entity" }
	attach = { ringworld_south 		= "biomass_01_ringworld_3x_seams_entity" }
	attach = { ringworld_west 		= "biomass_01_ringworld_3x_seams_entity" }
	attach = { ringworld_east 		= "biomass_01_ringworld_3x_seams_entity" }
	
	game_data = {
		shader_type = ship
		emissive_recolor_crunch = 10.0
	}
}


